{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "pages/pontok.html", "destination": "index.html" },
      { "source": "pages/roulette.html", "destination": "index.html" }
    ]
  }
}
